{
  "name": "pokelike-reborn",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A Pokemon-like roguelike game monorepo",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm -w packages/core run build",
    "lint": "eslint packages/",
    "format": "prettier --check \"packages/**/*.{ts,tsx,json}\"",
    "format:fix": "prettier --write \"packages/**/*.{ts,tsx,json}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0"
  }
}
